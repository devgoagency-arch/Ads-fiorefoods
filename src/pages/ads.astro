<!-- 
  Layout de Astro con Indexación habilitada y GTM.
  ── ID DE CONTENEDOR GOOGLE TAG MANAGER ──
  Reemplaza 'GTM-XXXXXXX' con tu ID real de contenedor de analítica.
-->
<Layout 
  title="Specialty and Fine Foods for Your Store | Fiore Foods Canada" 
  robots="index, follow"
  gtmId="GTM-5F538CSW"
>

  <!-- ════════════════════════════════════════════════════════════
       1 · HERO SECTION — SPLIT LAYOUT (Texto a la Izquierda, Formulario a la Derecha)
       ════════════════════════════════════════════════════════════════ -->
  <section class="relative bg-cream py-12 md:py-20 overflow-hidden border-b border-gray-100">
    <!-- Hojas decorativas de fondo -->
    <div class="absolute inset-0 flex items-end justify-start pointer-events-none overflow-hidden opacity-10">
      <img src="/img/olives-4 (1).png" alt="" class="w-64 -ml-10">
    </div>
    
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <!-- Lado Izquierdo (Texto de Pauta Directa e Impactante) -->
        <div class="lg:col-span-7 flex flex-col justify-center">
          <span class="font-rob text-xs font-bold uppercase tracking-widest mb-3 block" style="color: #acb370">
            Premium Importer & Distributor
          </span>
          <h1 class="font-cap leading-tight mb-6 text-brand" style="font-size: clamp(28px, 4.5vw, 44px); color: #80131d;">
            Specialty and Fine Foods<br class="hidden md:inline"> for Your Store
          </h1>
          <p class="font-rob text-lg md:text-xl text-gray-700 leading-relaxed mb-6 font-light">
            We distribute exclusive Spanish, Italian, and Mediterranean gourmet brands to specialty food stores, fine food retailers, and independent grocers across Canada. 
            <span class="font-semibold block mt-2 text-carbon">Direct import from Spain & Italy.</span>
          </p>
          <div class="border-t border-gray-200/60 pt-6 mt-2">
            <p class="font-rob text-[15px] md:text-base text-gray-500 leading-relaxed">
              <strong class="font-bold text-brand" style="color: #80131d;">400+ specialty SKUs</strong> · Ontario · Quebec · BC · Alberta · Wholesale pricing for retailers
            </p>
          </div>
        </div>

        <!-- Lado Derecho (Formulario Aislado de Lead) -->
        <div class="lg:col-span-5 w-full">
          <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100/50">
            <AdsForm />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       2 · SECCIÓN FEATURED PRODUCTS (Grid Layout - 1 Columna en móvil, 2 en md+)
       ════════════════════════════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-6">
      
      <div class="text-center mb-12">
        <p class="font-rob font-medium text-xs tracking-[.25em] uppercase mb-2" style="color:#acb370">Our Selection</p>
        <h2 class="font-cap text-3xl text-brand" style="color:#80131d">Featured Importing Brands</h2>
        <p class="font-rob text-sm text-gray-500 mt-2">Direct placement of premium Mediterranean specialties in Canada</p>
      </div>

      <!-- UX RESTRICCIÓN: 1 Columna en móvil, 2 en md+ -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {FEATURED_PRODUCTS.map((prod) => (
          <div class="group flex items-center p-5 bg-cream/35 border border-gray-100 rounded-3xl hover:shadow-md transition-all duration-300 gap-5">
            <!-- Imagen (Placeholder elegante) -->
            <div class="w-24 h-24 sm:w-28 sm:h-28 flex-shrink-0 bg-white border border-gray-100 rounded-2xl flex items-center justify-center overflow-hidden aspect-square relative">
              <img 
                src={prod.img} 
                alt={prod.name} 
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            
            <!-- Datos del producto -->
            <div class="flex-1 min-w-0">
              <h3 class="font-cap text-base sm:text-lg text-carbon leading-snug font-bold mb-2 truncate">
                {prod.name}
              </h3>
              <!-- Categoría pequeña y acentuada -->
              <span class="inline-block px-3 py-1 bg-white text-xs font-bold uppercase tracking-wider rounded-full border border-gray-100/60" style="color: #80131d;">
                {prod.category}
              </span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       3 · BRANDS CAROUSEL SECTION (Autoplay + Manual Controls + Mobile Grid 1-Col)
       ════════════════════════════════════════════════════════════════ -->
  <section class="py-16 bg-cream/30 border-t border-b border-gray-100/60">
    <div class="max-w-6xl mx-auto px-6">
      
      <div class="text-center mb-10">
        <p class="font-rob font-medium text-xs tracking-[.25em] uppercase mb-2" style="color:#acb370">Brand Portfolios</p>
        <h2 class="font-cap text-3xl text-brand" style="color:#80131d">Explore Our Exclusive Partners</h2>
        <p class="font-rob text-sm text-gray-500 mt-2">Browse the catalog by brand · Click to see active selections</p>
      </div>

      <!-- Carrusel de Marcas -->
      <div id="brands-carousel-container" class="relative">
        
        <!-- Píldoras de Navegación de Marcas -->
        <div class="flex flex-wrap items-center justify-center gap-2 mb-8" id="carousel-pills">
          {BRANDS_DATA.map((brand, idx) => (
            <button 
              type="button" 
              data-index={idx}
              class={`carousel-pill btn px-5 py-2.5 text-sm font-rob rounded-full border transition-all ${
                idx === 0 
                  ? 'btn-red shadow-sm' 
                  : 'bg-white border-gray-200 text-gray-600 hover:border-brand hover:text-brand'
              }`}
            >
              {brand.name}
            </button>
          ))}
        </div>

        <!-- Área de Visualización del Carrusel (Viewport) -->
        <div class="relative overflow-hidden bg-white border border-gray-100 rounded-3xl p-6 sm:p-8 min-h-[400px]">
          
          <!-- Controles de Flecha Manuales -->
          <!-- Izquierda -->
          <button 
            type="button" 
            id="carousel-prev" 
            class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-cream hover:bg-brand text-brand hover:text-white flex items-center justify-center shadow-sm z-20 border border-gray-200/50 transition-colors"
            aria-label="Previous Brand"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          
          <!-- Derecha -->
          <button 
            type="button" 
            id="carousel-next" 
            class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-cream hover:bg-brand text-brand hover:text-white flex items-center justify-center shadow-sm z-20 border border-gray-200/50 transition-colors"
            aria-label="Next Brand"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>

          <!-- Slides de las Marcas (Visibilidad alternada en JS) -->
          {BRANDS_DATA.map((brand, brandIdx) => (
            <div 
              id={`brand-slide-${brandIdx}`}
              class={`brand-slide transition-opacity duration-500 ${brandIdx === 0 ? 'block' : 'hidden'}`}
            >
              <div class="text-center mb-6 px-10">
                <span class="font-rob text-xs font-bold text-gray-400 uppercase tracking-widest">Brand Spotlight</span>
                <h3 class="font-cap text-2xl text-brand mt-1" style="color: #80131d;">{brand.name}</h3>
              </div>

              <!-- UX RESTRICCIÓN: Grid Interior 2x2. 1 Columna en móvil, 2 en md+ -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto px-4">
                {brand.products.map((prod) => (
                  <div class="flex items-center p-4 bg-cream/15 border border-cream/50 rounded-2xl gap-4 hover:border-brand/40 transition-colors">
                    <!-- Thumbnail del producto -->
                    <div class="w-16 h-16 sm:w-20 sm:h-20 bg-white border border-gray-100 rounded-xl flex-shrink-0 overflow-hidden relative">
                      <img src={prod.img} alt={prod.name} class="absolute inset-0 w-full h-full object-cover" />
                    </div>
                    <!-- Nombre y Categoría -->
                    <div class="min-w-0 flex-1">
                      <h4 class="font-cap text-sm sm:text-base font-bold text-carbon truncate">{prod.name}</h4>
                      <p class="font-rob text-xs font-bold uppercase tracking-wider mt-1" style="color: #acb370;">{prod.category}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}

          <!-- Dots Indicadores Manuales -->
          <div class="flex items-center justify-center gap-2 mt-8" id="carousel-dots">
            {BRANDS_DATA.map((_, idx) => (
              <button 
                type="button" 
                data-index={idx}
                class={`carousel-dot w-3 h-3 rounded-full transition-all border ${
                  idx === 0 
                    ? 'bg-brand border-brand w-5' 
                    : 'bg-gray-200 border-transparent hover:bg-gray-400'
                }`}
                aria-label={`Go to brand ${idx + 1}`}
              />
            ))}
          </div>

        </div>

        <!-- CTA Principal debajo del Carrusel (Smooth Scroll al Formulario del Hero) -->
        <div class="text-center mt-10">
          <button 
            type="button" 
            id="cta-scroll-top"
            class="btn btn-red px-10 py-4 font-cap text-base shadow-lg transition-transform hover:-translate-y-0.5"
          >
            Get Wholesale Catalog & Prices
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 13l-7 7-7-7m14-6l-7 7-7-7" />
            </svg>
          </button>
        </div>

      </div>

    </div>
  </section>

  <!-- Script del Carrusel e Interacciones de Navegación -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      let activeIndex = 0;
      const totalSlides = 6;
      let autoplayTimer = null;
      const autoplayDelay = 5000; // Rotación automática cada 5 segundos

      const pills = document.querySelectorAll('.carousel-pill');
      const slides = document.querySelectorAll('.brand-slide');
      const dots = document.querySelectorAll('.carousel-dot');
      
      const prevBtn = document.getElementById('carousel-prev');
      const nextBtn = document.getElementById('carousel-next');
      const ctaBtn = document.getElementById('cta-scroll-top');

      // Función core de actualización visual
      function updateCarousel(newIndex) {
        // Ocultar slide anterior, remover clases de botones y dots
        slides[activeIndex].classList.add('hidden');
        slides[activeIndex].classList.remove('block');
        
        pills[activeIndex].classList.remove('btn-red', 'shadow-sm');
        pills[activeIndex].classList.add('bg-white', 'border-gray-200', 'text-gray-600');
        
        dots[activeIndex].classList.remove('bg-brand', 'border-brand', 'w-5');
        dots[activeIndex].classList.add('bg-gray-200', 'border-transparent');

        // Actualizar índice activo
        activeIndex = newIndex;

        // Mostrar nuevo slide activo y actualizar botones/dots
        slides[activeIndex].classList.remove('hidden');
        slides[activeIndex].classList.add('block');
        
        pills[activeIndex].classList.remove('bg-white', 'border-gray-200', 'text-gray-600');
        pills[activeIndex].classList.add('btn-red', 'shadow-sm');
        
        dots[activeIndex].classList.remove('bg-gray-200', 'border-transparent');
        dots[activeIndex].classList.add('bg-brand', 'border-brand', 'w-5');
      }

      // Lógica de Autoplay con reseteo seguro
      function startAutoplay() {
        stopAutoplay();
        autoplayTimer = setInterval(() => {
          const nextIndex = (activeIndex + 1) % totalSlides;
          updateCarousel(nextIndex);
        }, autoplayDelay);
      }

      function stopAutoplay() {
        if (autoplayTimer) {
          clearInterval(autoplayTimer);
          autoplayTimer = null;
        }
      }

      // ── Eventos de interacción manual ──
      // Clic en las píldoras superiores
      pills.forEach((pill) => {
        pill.addEventListener('click', () => {
          stopAutoplay();
          const targetIdx = parseInt(pill.getAttribute('data-index'));
          if (targetIdx !== activeIndex) {
            updateCarousel(targetIdx);
          }
          startAutoplay();
        });
      });

      // Clic en los dots de paginación
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          stopAutoplay();
          const targetIdx = parseInt(dot.getAttribute('data-index'));
          if (targetIdx !== activeIndex) {
            updateCarousel(targetIdx);
          }
          startAutoplay();
        });
      });

      // Clic en flecha anterior
      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          stopAutoplay();
          const targetIdx = (activeIndex - 1 + totalSlides) % totalSlides;
          updateCarousel(targetIdx);
          startAutoplay();
        });
      }

      // Clic en flecha siguiente
      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          stopAutoplay();
          const targetIdx = (activeIndex + 1) % totalSlides;
          updateCarousel(targetIdx);
          startAutoplay();
        });
      }

      // Inicializar autoplay
      startAutoplay();

      // CTA Smooth Scroll hacia el formulario del Hero
      if (ctaBtn) {
        ctaBtn.addEventListener('click', () => {
          const formElement = document.getElementById('ads-preorder');
          if (formElement) {
            formElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      }
    });
  </script>

  <!-- Estilos embebidos específicos para complementar el carrusel de pauta -->
  <style is:global>
    /* Aseguramos que la clase de botón activo 'btn-red' de la píldora mantenga la armonía */
    .carousel-pill.btn-red {
      background-color: #80131d !important;
      color: #ffffff !important;
      border-color: #80131d !important;
    }
    .bg-brand {
      background-color: #80131d !important;
    }
    .border-brand {
      border-color: #80131d !important;
    }
    .text-brand {
      color: #80131d !important;
    }
  </style>

</Layout>
