---
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  robots?: string;
  gtmId?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const { 
  title, 
  robots = "index, follow", 
  gtmId,
  ogTitle = "Specialty and Fine Foods for Your Store | Fiore Foods Canada",
  ogDescription = "We distribute exclusive Spanish, Italian, and Mediterranean gourmet brands to specialty food stores, fine food retailers, and independent grocers across Canada. Direct import from Spain & Italy.",
  ogImage = "/img/fiore-foods-canada-spain-italy-mediterranean-food-Ontario.jpg"
} = Astro.props;

const canonicalImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.url).toString();
---

<!DOCTYPE html>
<html lang="en-CA" class="scroll-smooth">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NFWNWXRH');
  </script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8">
  <meta name="robots" content={robots}>

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{title}</title>
  <meta name="description" content={ogDescription} />
  
  <!-- Open Graph & Twitter Cards -->
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image" content={canonicalImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Cloudflare Turnstile -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <link rel="icon" type="image/png" href="/favicon.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Capriola&family=Roboto:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Roboto', sans-serif; background: #f5f3ef; color: #333; }

    /* ── Cart badge pulse ── */
    @keyframes pulse-scale {
      0%   { transform: scale(1); }
      45%  { transform: scale(1.28); }
      100% { transform: scale(1); }
    }
    .do-pulse { animation: pulse-scale 0.28s ease; }

    /* ── Qty input: hide native arrows ── */
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    input[type=number] { -moz-appearance: textfield; }

    /* ── Focus ring for form fields ── */
    .fld:focus { outline: none; border-color: #80131d; box-shadow: 0 0 0 3px rgba(128,19,29,0.13); }

    /* ── Product row hover ── */
    .prow { transition: box-shadow .2s, transform .2s; }
    .prow:hover { box-shadow: 0 6px 28px rgba(128,19,29,.11); transform: translateY(-1px); }

    /* ── Pill buttons ── */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      border-radius: 9999px; cursor: pointer; font-weight: 500;
      transition: background .18s, color .18s, box-shadow .18s;
      border: none;
    }
    .btn-red { background: #80131d; color: #fff; }
    .btn-red:hover { background: #a81624; box-shadow: 0 4px 16px rgba(128,19,29,.35); }
    .btn-outline { background: transparent; color: #80131d; border: 1.5px solid #80131d; }
    .btn-outline:hover { background: #80131d; color: #fff; }

    /* ── Scrollbar (modal) ── */
    .scr::-webkit-scrollbar { width: 4px; }
    .scr::-webkit-scrollbar-track { background: #f5f3ef; }
    .scr::-webkit-scrollbar-thumb { background: #acb370; border-radius: 99px; }

    /* ── Two-line clamp ── */
    .clamp2 {
      display: -webkit-box; -webkit-line-clamp: 2;
      -webkit-box-orient: vertical; overflow: hidden;
    }

    /* ── Hero split ── */
    .hero-left  { background: #8B9765; }

    /* ── About botanical float ── */
    .botanical-float {
      position: absolute; right: 44%; top: -10px;
      opacity: .12; pointer-events: none; user-select: none;
    }

    /* ── Footer bottom strip ── */
    .footer-strip { background: #c4bbaa; }

    /* ── Step divider arrow ── */
    .arrow-step { color: rgba(255,255,255,.38); font-size: 1.8rem; line-height: 1; }

    /* ── Modal backdrop blur ── */
    #modal { backdrop-filter: blur(4px); }
  </style>
</head>

<body class="bg-cream font-rob">
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NFWNWXRH"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<div class="parallax-container">

<!-- ════════════════════════════════════════════════════════════
     1 · STICKY HEADER
════════════════════════════════════════════════════════════════ -->
<header id="top" class="sticky top-0 z-50 bg-white" style="box-shadow:0 2px 18px rgba(0,0,0,.09)">
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">

    <!-- ── Fiore Foods Logo ── -->
    <a href="#top" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;" class="flex items-center gap-2.5 flex-shrink-0 select-none" style="text-decoration:none">
      <img src="/img/logo-fiore.png" alt="Fiore Foods Logo" class="w-32 object-contain">
    </a>

    <!-- ── Right: Contact Us ── -->
    <div class="flex items-center gap-3">
      <a href="#ads-preorder" class="btn btn-outline px-5 py-2 text-sm font-rob">Contact Us</a>
    </div>

  </div>
</header>

<slot />

<Footer />

</div>

<!-- Floating back to top button -->
<button id="btn-back-catalog" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" class="fixed bottom-6 right-6 w-14 h-14 rounded-full flex items-center justify-center shadow-lg transition-all duration-300 opacity-0 pointer-events-none z-[100]" style="background:#80131d; color:white" title="Scroll to Top">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
  </svg>
</button>

<!-- ════════════════════════════════════════════════════════════
     DETAILS MODAL
════════════════════════════════════════════════════════════════ -->
<div id="details-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;">
  <div class="bg-white rounded-3xl w-full max-w-3xl max-h-[90vh] flex flex-col shadow-2xl overflow-hidden relative">
    <button onclick="closeDetailsModal()" type="button" class="absolute top-5 right-5 text-gray-400 hover:text-gray-800 transition-colors z-10" aria-label="Close">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    
    <div class="flex-1 overflow-y-auto scr flex flex-col sm:flex-row">
      <!-- Image -->
      <div class="w-full sm:w-2/5 aspect-square flex-shrink-0 relative group">
        <img id="details-img" src="" alt="" class="absolute inset-0 w-full h-full object-contain cursor-zoom-in"
             referrerpolicy="no-referrer"
             onerror="this.src='https://placehold.co/600x600?text=No+Image+Found'; this.onerror=null;">
        <svg xmlns="http://www.w3.org/2000/svg" class="absolute top-3 right-3 z-10 bg-white/70 p-2 rounded-full shadow-sm text-gray-800 backdrop-blur-sm pointer-events-none w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      
      <!-- Content -->
      <div class="flex-1 px-8 py-8 flex flex-col">
        <h3 id="details-title" class="font-cap text-2xl text-carbon leading-snug mb-2 pr-6"></h3>
        <p class="font-rob text-xs font-medium mb-4" style="color:#888"><span class="font-bold text-brand">Case Size:</span> <span id="details-size"></span></p>
        <div id="details-desc" class="font-rob text-sm text-gray-600 leading-relaxed space-y-3 flex-1 mb-6"></div>
        
        <!-- Modal Price & Qty Block -->
        <div class="mt-auto pt-5 border-t border-gray-100">
          <div class="flex items-center justify-between gap-4 mb-5">
            <div>
              <span id="details-price" class="font-cap text-brand text-2xl leading-none" style="color:#80131d"></span>
              <span class="font-rob text-gray-400 text-sm"> / case</span>
            </div>
            
            <!-- Qty stepper (Modal) -->
            <div class="flex items-center gap-1 rounded-full p-1" style="background:#f5f3ef">
              <button onclick="modalChangeQty(-1)" type="button" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xl leading-none select-none transition-all duration-150" style="background:white;color:#80131d;box-shadow:0 1px 4px rgba(0,0,0,.12)" onmouseenter="this.style.background='#80131d';this.style.color='white'" onmouseleave="this.style.background='white';this.style.color='#80131d'">−</button>
              <input id="modal-qty" type="number" value="0" min="0" max="999" onchange="modalSetQty(parseInt(this.value)||0)" oninput="modalSetQty(parseInt(this.value)||0)" class="w-12 text-center bg-transparent font-bold text-sm font-rob focus:outline-none" style="color:#1a1a1a">
              <button onclick="modalChangeQty(+1)" type="button" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xl leading-none select-none transition-all duration-150" style="background:#80131d;color:white;box-shadow:0 1px 4px rgba(128,19,29,.3)" onmouseenter="this.style.background='#a81624'" onmouseleave="this.style.background='#80131d'">+</button>
            </div>
          </div>
          
          <div class="flex justify-between items-center">
             <div id="modal-line" class="hidden text-sm font-rob text-right font-medium" style="color:#555"></div>
             <button onclick="closeDetailsModal()" type="button" class="btn btn-red px-8 py-3 text-sm font-rob ml-auto">Done</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- ZOOM OVERLAY -->
<div id="zoom-overlay" class="hidden fixed inset-0 z-[150] bg-black/90 cursor-zoom-out flex items-center justify-center backdrop-blur-md opacity-0 transition-opacity duration-300">
  <img id="zoom-img" src="" alt="Zoomed Product" class="max-w-[95vw] max-h-[95vh] object-contain transition-transform duration-300 scale-95" />
</div>

<script is:inline>
  // Global modal close function
  window.closeDetailsModal = function() {
    const modal = document.getElementById('details-modal');
    if (modal) modal.classList.add('hidden');
  };

  // Show/Hide Floating Button on window scroll
  window.addEventListener('scroll', () => {
    const btn = document.getElementById('btn-back-catalog');
    if (!btn) return;
    if (window.scrollY > 800) {
      btn.classList.remove('opacity-0', 'pointer-events-none');
      btn.classList.add('opacity-100', 'pointer-events-auto');
    } else {
      btn.classList.remove('opacity-100', 'pointer-events-auto');
      btn.classList.add('opacity-0', 'pointer-events-none');
    }
  });

  // Since modals are here, we attach the simple event listener to close on backdrop
  document.getElementById('details-modal')?.addEventListener('click', function(e) {
    if (e.target === this) closeDetailsModal();
  });

  // Zoom logic
  const detailsImg = document.getElementById('details-img');
  const zoomOverlay = document.getElementById('zoom-overlay');
  const zoomImg = document.getElementById('zoom-img');

  if (detailsImg && zoomOverlay && zoomImg) {
    detailsImg.addEventListener('click', () => {
      // Read the data-zoom-src (or fallback to src) to get the high-res image
      zoomImg.src = detailsImg.getAttribute('data-zoom-src') || detailsImg.src;
      zoomOverlay.classList.remove('hidden');
      // small delay to allow display:block to apply before animating opacity
      requestAnimationFrame(() => {
        zoomOverlay.classList.remove('opacity-0');
        zoomImg.classList.remove('scale-95');
        zoomImg.classList.add('scale-100');
      });
    });

    const closeZoom = () => {
      zoomOverlay.classList.add('opacity-0');
      zoomImg.classList.remove('scale-100');
      zoomImg.classList.add('scale-95');
      setTimeout(() => zoomOverlay.classList.add('hidden'), 300);
    };

    zoomOverlay.addEventListener('click', closeZoom);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (!zoomOverlay.classList.contains('hidden')) {
          closeZoom();
        } else if (document.getElementById('details-modal') && !document.getElementById('details-modal').classList.contains('hidden')) {
          closeDetailsModal();
        }
      }
    });
  }
</script>

</body>
</html>
