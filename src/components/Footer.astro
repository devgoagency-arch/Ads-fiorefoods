---
// src/components/Footer.astro
---
<footer id="footer" style="background:#f5f3ef; border-top:1px solid #e8e3db">
  <div class="max-w-7xl mx-auto px-8 pt-14 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <img src="/img/logo-fiore.png" alt="Fiore Foods Logo" class="w-32 object-contain">
        </div>
        <p class="font-rob font-bold text-xs leading-relaxed tracking-wider uppercase" style="color:#80131d">
          Specialty and Fine Food<br>Distributor in Canada
        </p>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-cap text-base mb-5" style="color:#80131d">Company</h4>
        <ul class="font-rob text-[15px] space-y-2.5 text-gray-500">
          <li><a href="https://fiorefoodscanada.com/" class="hover:text-[#80131d] transition-colors" target="_blank" rel="noopener noreferrer">Home</a></li>
          <li><a href="https://fiorefoodscanada.com/who-we-are" class="hover:text-[#80131d] transition-colors" target="_blank" rel="noopener noreferrer">Who we are</a></li>
          <li><a href="https://fiorefoodscanada.com/shop" class="hover:text-[#80131d] transition-colors" target="_blank" rel="noopener noreferrer">Shop</a></li>
          <li><a href="https://fiorefoodscanada.com/contact-us" class="hover:text-[#80131d] transition-colors" target="_blank" rel="noopener noreferrer">Contact us</a></li>
        </ul>
      </div>

      <!-- Get in touch -->
      <div>
        <h4 class="font-cap text-base mb-5" style="color:#80131d">Get in touch</h4>
        <ul class="font-rob text-[15px] space-y-2.5 text-gray-500">
          <li><a href="mailto:info@fiorefoodscanada.com" class="hover:text-[#80131d] transition-colors">info@fiorefoodscanada.com</a></li>
          <li><a href="tel:+19057277900" class="hover:text-[#80131d] transition-colors">Call us: +1 (905) 727-7900</a></li>
          <li class="text-[13px] text-gray-400 leading-relaxed mt-1">
            <a href="https://www.google.com/maps/place/9+Allaura+Blvd+%231A,+Aurora,+ON+L4G+3N2,+Canada/@43.9834746,-79.4636559,17z/data=!3m1!4b1!4m5!3m4!1s0x882ad4067b3aaaab:0x8aa464dc1e2c1403!8m2!3d43.9834708!4d-79.4614672?shorturl=1" target="_blank" rel="noopener noreferrer" class="hover:text-[#80131d] transition-colors block">
              9 Allaura Blvd. Unit 1,<br>Aurora, Ontario, Canada. L4G 3N2.
            </a>
          </li>
        </ul>
      </div>

      <!-- Follow us -->
      <div>
        <h4 class="font-cap text-sm mb-5" style="color:#80131d">Follow us</h4>
        <a href="https://www.instagram.com/fiorefoodscanada/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full border flex items-center justify-center transition-colors group hover:border-[#80131d]"
                style="border-color:#ccc" aria-label="Instagram">
          <svg class="w-4 h-4 text-gray-400 group-hover:text-[#80131d] transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom strip -->
  <div class="footer-strip">
    <div class="max-w-7xl mx-auto px-8 py-4 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="font-rob text-[13px] text-gray-500">© 2021 Fiore Food · All Rights Reserved</p>
      <div class="flex gap-6 font-rob text-[13px] text-gray-500">
        <a href="/privacy-policy" class="hover:text-[#80131d] transition-colors open-privacy-modal">Privacy Policy</a>
        <a href="https://fiorefoodscanada.com/return-policy" target="_blank" rel="noopener noreferrer" class="hover:text-[#80131d] transition-colors">Return Policy</a>
        <a href="https://fiorefoodscanada.com/terms-and-conditions" target="_blank" rel="noopener noreferrer" class="hover:text-[#80131d] transition-colors">Terms and Conditions</a>
      </div>
    </div>
  </div>
</footer>
