---
import { Image } from 'astro:assets';

export interface Props {
  products: {
    id: number;
    sku: string;
    name: string;
    description: string;
    caseSize: string;
    price: number;
    img: string;
    category: string;
  }[];
}

const { products } = Astro.props;

const processedProducts = products.map((product) => {
  let quantity = 1;
  let showUnitPrice = false;

  if (product.caseSize && typeof product.caseSize === 'string') {
    const parts = product.caseSize.toLowerCase().split('x');
    if (parts.length > 1) {
      const parsedQty = parseInt(parts[0].trim(), 10);
      if (!isNaN(parsedQty) && parsedQty > 0) {
        quantity = parsedQty;
        showUnitPrice = true;
      }
    }
  }

  const unitPrice = (product.price / quantity).toFixed(2);

  return {
    ...product,
    unitPrice,
    showUnitPrice
  };
});
---

<!-- ════════════════════════════════════════════════════════════
     4 · PRODUCT CATALOGUE — LIST VIEW
════════════════════════════════════════════════════════════════ -->
<section id="catalogue" class="py-16">
  <div class="max-w-[1440px] mx-auto px-6">

    <div class="text-center mb-10">
      <p class="font-rob font-medium text-xs tracking-[.2em] uppercase mb-2" style="color:#acb370">Our Selection</p>
      <h2 class="font-cap text-3xl" style="color:#a81624">Curated Wholesale Products</h2>
      <p class="font-rob text-sm text-gray-500 mt-2">All prices are per case (CAD) · Subject to stock confirmation</p>
    </div>

    <!-- Filters rendered by JS -->
    <div id="category-filters-container" class="sticky z-40 bg-cream py-4 mb-8" style="top:96px;">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-4 relative">
        <!-- Desktop Pills -->
        <div id="category-filters-desktop" class="hidden sm:flex flex-wrap items-center justify-start gap-2 flex-1"></div>
        
        <!-- Mobile Dropdown -->
        <div id="category-filters-mobile" class="sm:hidden w-full relative">
          <button onclick="toggleMobileCategories()" type="button" class="w-full flex items-center justify-between bg-white px-4 py-2.5 rounded-full border border-gray-200 text-sm font-medium font-rob shadow-sm">
            <span id="mobile-category-label">Filter by Category: All</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div id="mobile-category-dropdown" class="hidden absolute top-full left-0 w-full mt-2 bg-white border border-gray-100 rounded-xl shadow-lg z-50 overflow-hidden"></div>
        </div>

        <!-- Go to Cart -->
        <button type="button" onclick="if(window.goToForm) window.goToForm(); else document.getElementById('preorder')?.scrollIntoView({behavior: 'smooth'})" class="btn btn-outline px-4 py-2 text-xs font-rob whitespace-nowrap bg-cream hover:bg-[#80131d] flex-shrink-0">↓ Go to Cart</button>
      </div>
    </div>

    <!-- Products pre-rendered by Astro, visibility toggled by JS -->
    <div id="product-list" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {processedProducts.map(p => (
        <div class="prow bg-white rounded-3xl overflow-hidden flex flex-row flex-wrap sm:flex-nowrap items-center p-4 gap-4 shadow-sm transition-colors duration-200 hidden" style="border:1px solid #f0ece6; display: none;" data-id={p.id} data-category={p.category}>

          <!-- Product image -->
          <div class="w-24 h-24 sm:w-32 sm:h-32 flex-shrink-0 bg-white rounded-xl flex items-center justify-center overflow-hidden aspect-square relative" onclick={`openDetailsModal(${p.id})`}>
            {p.img ? (
              <Image src={p.img} alt={p.name} width={300} height={300} 
                class="absolute inset-0 w-full h-full object-cover cursor-pointer transition-transform hover:scale-105" 
                data-zoom-src={p.img} />
            ) : (
              <div class="absolute inset-0 w-full h-full bg-gray-100 flex items-center justify-center text-gray-400 text-xs">No Image</div>
            )}
          </div>

          <!-- Info + controls -->
          <div class="flex-1 min-w-0 flex flex-wrap items-center justify-between gap-4">
            <!-- Text info -->
            <div class="flex-1 min-w-[220px] pr-2">
              <h3 class="font-cap text-carbon leading-snug mb-1 text-sm sm:text-base lg:text-lg font-bold">{p.name}</h3>
              <p class="font-rob text-gray-500 text-[13px] sm:text-sm leading-relaxed mb-2 clamp2" set:html={p.description}></p>
              <button type="button" onclick={`openDetailsModal(${p.id}); return false;`} class="btn btn-red px-4 py-1 text-[13px] mb-2">Details</button>
              <p class="font-rob text-sm font-medium" style="color:#888"><span class="font-bold text-brand">Case Size:</span> {p.caseSize}</p>
            </div>

            <!-- Price + qty -->
            <div class="w-full sm:w-auto flex flex-wrap items-center justify-between gap-3 flex-shrink-0">
              <!-- Price -->
              <div class="flex flex-col text-left sm:text-right whitespace-nowrap justify-center">
                <div>
                  <span class="font-cap text-brand text-2xl leading-none" style="color:#80131d">${p.price.toFixed(2)}</span>
                  <span class="font-rob text-gray-400 text-sm"> / case</span>
                </div>
                {p.showUnitPrice && <span class="text-sm text-gray-500 mt-1">${p.unitPrice} / unit</span>}
              </div>

              <!-- Qty stepper -->
              <div class="flex items-center gap-1 rounded-full p-1" style="background:#f5f3ef">
                <button onclick={`changeQty(${p.id},-1)`} type="button" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xl leading-none select-none transition-all duration-150" style="background:white;color:#80131d;box-shadow:0 1px 4px rgba(0,0,0,.12)" onmouseenter="this.style.background='#80131d';this.style.color='white'" onmouseleave="this.style.background='white';this.style.color='#80131d'" aria-label="Decrease">−</button>
                <input id={`qty-${p.id}`} type="number" value="0" min="0" max="999" aria-label={`Quantity for ${p.name}`} onchange={`setQty(${p.id}, parseInt(this.value)||0)`} oninput={`setQty(${p.id}, parseInt(this.value)||0)`} class="w-12 text-center bg-transparent font-bold text-base font-rob focus:outline-none" style="color:#1a1a1a" />
                <button onclick={`changeQty(${p.id},+1)`} type="button" class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-xl leading-none select-none transition-all duration-150" style="background:#80131d;color:white;box-shadow:0 1px 4px rgba(128,19,29,.3)" onmouseenter="this.style.background='#a81624'" onmouseleave="this.style.background='#80131d'" aria-label="Increase">+</button>
              </div>

              <!-- Line total (shown when qty > 0) -->
              <div id={`line-${p.id}`} class="hidden text-sm font-rob text-right" style="color:#555">Subtotal: $0.00 CAD</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Sentinel for Infinite Scroll -->
    <div id="sentinel" class="h-10 mt-4"></div>

  </div>
</section>

<!-- ════════════════════════════════════════════════════════════
     6 · PRE-ORDER FORM
════════════════════════════════════════════════════════════════ -->
<section id="preorder" class="py-16 bg-cream">
  <div class="max-w-3xl mx-auto px-6">

    <div class="text-center mb-10">
      <p class="font-rob font-medium text-xs tracking-[.2em] uppercase mb-2" style="color:#acb370">Ready to Order?</p>
      <h2 class="font-cap text-3xl" style="color:#a81624">Submit Your Pre-Order</h2>
      <p class="font-rob text-sm text-gray-500 mt-2">Our team will confirm availability within 24–48 business hours.</p>
    </div>

    <!-- Order summary card -->
    <div class="bg-white rounded-3xl p-6 mb-5 shadow-sm border border-cream">
      <h3 class="font-cap mb-4 flex items-center gap-2 text-base" style="color:#80131d">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        Order Summary
      </h3>
      <div id="sum-body" class="font-rob text-sm">
        <p class="text-gray-400 italic text-sm">No items selected — browse the catalogue above to add products.</p>
      </div>
      <div id="sum-totals" class="hidden border-t pt-4 mt-4 space-y-1" style="border-color:#f5f3ef">
        <div class="flex justify-between text-sm font-medium">
          <span class="font-cap" style="color:#1a1a1a">Total Cases:</span>
          <span id="tot-cases" class="text-gray-700">0</span>
        </div>
        <div class="flex justify-between text-sm font-semibold">
          <span class="font-cap" style="color:#80131d">Estimated Total:</span>
          <span id="tot-price" style="color:#80131d">$0.00 CAD</span>
        </div>
        <p class="text-gray-400 text-xs pt-1">*Estimate only. Final pricing confirmed on order review.</p>
      </div>
    </div>

    <!-- Form -->
    <form id="order-form" onsubmit="handleSubmit(event)" class="bg-white rounded-3xl p-8 shadow-sm border border-cream">
      <div class="grid sm:grid-cols-2 gap-5">

        <div class="flex flex-col gap-1.5">
          <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Full Name <span style="color:#80131d">*</span></label>
          <input id="f-name" type="text" required placeholder="Jane Smith" class="fld w-full border border-gray-200 rounded-full px-4 py-2.5 text-base font-rob transition-all">
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Company Name <span style="color:#80131d">*</span></label>
          <input id="f-company" type="text" required placeholder="Acme Fine Foods Inc." class="fld w-full border border-gray-200 rounded-full px-4 py-2.5 text-base font-rob transition-all">
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Email Address <span style="color:#80131d">*</span></label>
          <input id="f-email" type="email" required placeholder="jane@acmefoods.ca" class="fld w-full border border-gray-200 rounded-full px-4 py-2.5 text-base font-rob transition-all">
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Business Category <span style="color:#80131d">*</span></label>
          <div class="relative">
            <select id="f-category" required class="fld w-full border border-gray-200 rounded-full px-4 py-2.5 text-base font-rob transition-all appearance-none bg-white pr-8">
              <option value="" disabled selected>Select your category…</option>
              <option>Specialty Food Store</option>
              <option>Restaurant / Café</option>
              <option>Cheese Shop</option>
              <option>Online Market</option>
              <option>Hotel / Hospitality</option>
              <option>Supermarket / Grocery</option>
              <option>Other</option>
            </select>
            <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </div>

      </div>

      <div class="flex flex-col gap-1.5 mt-5">
        <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Additional Notes</label>
        <textarea id="f-notes" rows="3" placeholder="Delivery requirements, special requests, questions…" class="fld w-full border border-gray-200 rounded-2xl px-4 py-3 text-base font-rob transition-all resize-none"></textarea>
      </div>

      <div class="mt-7 text-center">
        <!-- Cloudflare Turnstile Widget -->
        <div class="cf-turnstile mb-4 flex justify-center" data-sitekey="0x4AAAAAADGdWFU5FsRD_Aa5" data-callback="onTurnstileSuccess"></div>
        <div class="flex flex-col-reverse sm:flex-row items-center justify-center gap-4">
          <button type="button" onclick="document.getElementById('catalogue')?.scrollIntoView({behavior: 'smooth'})" class="btn btn-outline px-8 py-3.5 font-cap text-base bg-white hover:bg-[#80131d]">
            ↑ Keep Shopping
          </button>
          <button type="submit" class="btn btn-red px-10 py-3.5 font-cap text-base">
            Send Pre-Order Request
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>
        </div>
        <p class="text-gray-400 text-xs mt-3 font-rob">
          This is a pre-order request — not a confirmed purchase. A Fiore Foods representative will follow up shortly.<br>
          *Final sale. No returns or exchanges.
        </p>
      </div>

    </form>
  </div>
</section>

<!-- Send props to global window to bypass scoping -->
<script is:inline set:html={`window.BASE_PRODUCTS = ${JSON.stringify(processedProducts)};`} />

<script is:inline>
// ── Product data ─────────────────────────────────────────────
const BASE_PRODUCTS = window.BASE_PRODUCTS || [];

// Connect directly to backend payload injected through the Astro prop
const PRODUCTS = BASE_PRODUCTS.map(p => ({
  ...p,
  qty: 0,
}));

// Dynamically extract categories directly from payload attributes
const allCats = PRODUCTS.map(p => p.category).filter(c => c && c !== 'Uncategorized');
const CATEGORIES = [...new Set(allCats)].sort();

let activeCategory = CATEGORIES.length > 0 ? CATEGORIES[0] : '';
let currentPage = 1;
const pageSize = 20;

function renderFilters() {
  const cats = [...CATEGORIES];
  
  // Desktop
  const desktopContainer = document.getElementById('category-filters-desktop');
  if(desktopContainer) {
    desktopContainer.innerHTML = cats.map(c => `
      <button onclick="filterProducts('${c}')" type="button" class="btn ${activeCategory === c ? 'btn-red' : 'btn-outline'} px-5 py-2 text-sm font-rob">${c}</button>
    `).join('');
  }

  // Mobile
  const mobileLabel = document.getElementById('mobile-category-label');
  const mobileDropdown = document.getElementById('mobile-category-dropdown');
  if(mobileLabel && mobileDropdown) {
    mobileLabel.textContent = `Filter by Category: ${activeCategory}`;
    mobileDropdown.innerHTML = cats.map(c => `
      <button onclick="filterProducts('${c}'); toggleMobileCategories();" type="button" class="w-full text-left px-4 py-3 text-sm font-rob border-b border-gray-50 last:border-0 ${activeCategory === c ? 'bg-cream text-brand font-bold' : 'hover:bg-gray-50 transition-colors'}">${c}</button>
    `).join('');
  }
}

function toggleMobileCategories() {
  const dropdown = document.getElementById('mobile-category-dropdown');
  if(dropdown) dropdown.classList.toggle('hidden');
}

function filterProducts(cat) {
  activeCategory = cat;
  currentPage = 1;
  renderFilters();
  renderProducts(false);
}

function loadMoreProducts() {
  const filtered = PRODUCTS.filter(p => p.category === activeCategory);
  if (currentPage * pageSize >= filtered.length) return;
  currentPage++;
  renderProducts(true);
}

// ── Render product rows ───────────────────────────────────────
function renderProducts(append = false) {
  const filtered = PRODUCTS.filter(p => p.category === activeCategory);
  const end = currentPage * pageSize;
  
  const allRows = document.querySelectorAll('.prow');
  
  allRows.forEach(row => {
    const rowId = parseInt(row.getAttribute('data-id'));
    const p = PRODUCTS.find(x => x.id === rowId);
    
    if (p && p.category === activeCategory) {
      const index = filtered.findIndex(x => x.id === rowId);
      if (index !== -1 && index < end) {
        row.style.display = 'flex';
        row.classList.remove('hidden');
      } else {
        row.style.display = 'none';
        row.classList.add('hidden');
      }
    } else {
      row.style.display = 'none';
      row.classList.add('hidden');
    }
  });

  const sentinel = document.getElementById('sentinel');
  if (sentinel) {
    if (end < filtered.length) {
      sentinel.style.display = 'block';
    } else {
      sentinel.style.display = 'none';
    }
  }
}

// ── Cart calculations ────────────────────────────────────────
function changeQty(id, delta) {
  const p  = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  p.qty    = Math.max(0, p.qty + delta);
  syncProduct(p);
  syncGlobal();
}
function setQty(id, val) {
  const p  = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  p.qty    = Math.max(0, isNaN(val) ? 0 : val);
  syncProduct(p);
  syncGlobal();
}

function syncProduct(p) {
  const listQty = document.getElementById(`qty-${p.id}`);
  if (listQty) listQty.value = p.qty;

  const modalQty = document.getElementById('modal-qty');
  if (modalQty && modalQty.dataset.id == p.id) {
    modalQty.value = p.qty;
  }

  const el = document.getElementById(`line-${p.id}`);
  if (el) {
    if (p.qty > 0) {
      el.textContent = `Subtotal: $${(p.qty * p.price).toFixed(2)} CAD`;
      el.classList.remove('hidden');
    } else {
      el.classList.add('hidden');
    }
  }

  const modalLine = document.getElementById('modal-line');
  if (modalLine && modalQty && modalQty.dataset.id == p.id) {
    if (p.qty > 0) {
      modalLine.textContent = `Subtotal: $${(p.qty * p.price).toFixed(2)} CAD`;
      modalLine.classList.remove('hidden');
    } else {
      modalLine.classList.add('hidden');
    }
  }

  const row = document.querySelector(`.prow[data-id="${p.id}"]`);
  if (row) {
    if (p.qty > 0) {
      row.classList.remove('bg-white');
      row.classList.add('bg-[#f5f3ef]');
      row.style.borderColor = '#80131d';
    } else {
      row.classList.remove('bg-[#f5f3ef]');
      row.classList.add('bg-white');
      row.style.borderColor = '#f0ece6';
    }
  }
}

function syncGlobal() {
  const totalUnits = PRODUCTS.reduce((s,p) => s + p.qty, 0);
  const totalAmt   = PRODUCTS.reduce((s,p) => s + p.qty * p.price, 0);

  // Header badge — show dollar total + unit count
  const hdrTotal = document.getElementById('hdr-total');
  const hdrUnits = document.getElementById('hdr-units');
  if(hdrTotal) hdrTotal.textContent = `$${totalAmt.toFixed(2)}`;
  if(hdrUnits) hdrUnits.textContent = `${totalUnits} case${totalUnits !== 1 ? 's' : ''}`;

  // Pulse animation
  if(hdrTotal) {
    hdrTotal.classList.remove('do-pulse');
    void hdrTotal.offsetWidth;
    hdrTotal.classList.add('do-pulse');
  }

  // Order summary panel
  refreshSummary(totalUnits, totalAmt);
}

// ── Order summary ────────────────────────────────────────────
function refreshSummary(units, amt) {
  const body   = document.getElementById('sum-body');
  const totals = document.getElementById('sum-totals');
  if(!body || !totals) return;
  const sel    = PRODUCTS.filter(p => p.qty > 0);

  if (!sel.length) {
    body.innerHTML = '<p class="text-gray-400 italic text-sm">No items selected — browse the catalogue above.</p>';
    totals.classList.add('hidden');
    return;
  }

  body.innerHTML = sel.map(p => `
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-3 last:border-0 gap-3" style="border-bottom:1px solid #f5f3ef">
      <div class="flex-1 min-w-0 pr-4">
        <p class="font-rob font-medium text-base truncate" style="color:#1a1a1a">${p.name}</p>
        <p class="font-rob text-sm text-gray-400 mt-1"><span class="font-bold text-brand">Case Size:</span> ${p.caseSize} &nbsp;·&nbsp; <code class="font-mono">${p.sku}</code></p>
      </div>
      
      <div class="flex items-center justify-between sm:justify-end gap-4 flex-shrink-0">
        <!-- Interactive Stepper -->
        <div class="flex items-center gap-1 rounded-full p-1" style="background:#f5f3ef; border: 1px solid #e8e3db;">
          <button onclick="changeQty(${p.id},-1)" type="button" class="w-6 h-6 rounded-full flex items-center justify-center font-bold text-lg leading-none transition-all duration-150 bg-white hover:bg-gray-100" style="color:#80131d;box-shadow:0 1px 2px rgba(0,0,0,.05)" aria-label="Decrease">−</button>
          <input type="number" value="${p.qty}" min="0" max="999" onchange="setQty(${p.id}, parseInt(this.value)||0)" oninput="setQty(${p.id}, parseInt(this.value)||0)" class="w-8 text-center bg-transparent font-bold text-base font-rob focus:outline-none" style="color:#1a1a1a">
          <button onclick="changeQty(${p.id},1)" type="button" class="w-6 h-6 rounded-full flex items-center justify-center font-bold text-lg leading-none transition-all duration-150" style="background:#80131d;color:white" aria-label="Increase">+</button>
        </div>

        <div class="text-right min-w-[70px]">
          <p class="font-rob text-base font-bold" style="color:#80131d">$${(p.qty*p.price).toFixed(2)}</p>
        </div>

        <!-- Remove item -->
        <button onclick="changeQty(${p.id}, -${p.qty})" type="button" class="text-gray-300 hover:text-red-500 transition-colors ml-1" title="Remove item">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
      </div>
    </div>
  `).join('');

  document.getElementById('tot-cases').textContent = `${units} case${units !== 1 ? 's' : ''}`;
  document.getElementById('tot-price').textContent  = `$${amt.toFixed(2)} CAD`;
  totals.classList.remove('hidden');
}

// ── Form submission ──────────────────────────────────────────
async function handleSubmit(e) {
  e.preventDefault();
  const sel = PRODUCTS.filter(p => p.qty > 0);
  if (!sel.length) { alert('Please select at least one product before submitting.'); return; }

  // Extract Turnstile token
  const formData = new FormData(e.target);
  const turnstileToken = formData.get('cf-turnstile-response');
  if (!turnstileToken) {
    alert('Please complete the security check to prove you are human.');
    return;
  }

  const submitBtn = e.target.querySelector('button[type="submit"]');
  if (submitBtn) {
    submitBtn.disabled = true;
    submitBtn.style.opacity = '0.7';
    submitBtn.style.cursor = 'not-allowed';
  }

  const payload = {
    event_type: 'preorder_submission',
    turnstile_token: turnstileToken,
    timestamp:  new Date().toISOString(),
    source:     'fiore-b2b-preorder-portal',
    customer_info: {
      name:     document.getElementById('f-name').value.trim(),
      company:  document.getElementById('f-company').value.trim(),
      email:    document.getElementById('f-email').value.trim(),
      category: document.getElementById('f-category').value,
      notes:    document.getElementById('f-notes').value.trim() || null,
    },
    order_items: sel.map(p => ({
      sku:            p.sku,
      name:           p.name,
      case_size:      p.caseSize,
      quantity_cases: p.qty,
      unit_price_cad: p.price,
      line_total_cad: parseFloat((p.qty * p.price).toFixed(2)),
    })),
    order_summary: {
      total_cases:  sel.reduce((s,p) => s + p.qty, 0),
      subtotal_cad: parseFloat(sel.reduce((s,p) => s + p.qty*p.price, 0).toFixed(2)),
      currency:     'CAD',
      status:       'pending_review',
    },
    quickbooks_meta: {
      document_type: 'SalesOrder',
      note:          'DO NOT invoice yet. Staff validates stock, then converts to Invoice in QB.',
      workflow:      '1. Search customer by email → 2. Create if not found → 3. Map SKU to QB Item ID → 4. Create Sales Order',
    },
  };

  try {
    const response = await fetch('https://hook.eu1.make.com/llk7hmjum559gzf5wg7523d3tf4eg6dv', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(payload)
    });

    if (response.ok) {
      PRODUCTS.forEach(p => {
        p.qty = 0;
        syncProduct(p);
      });
      syncGlobal();
      e.target.reset();
      
      alert('Your preorder request has been successfully submitted! We will confirm availability shortly.');
    } else {
      console.error('Submission failed with status:', response.status);
      alert('There was a problem submitting your request. Please try again.');
    }
  } catch (error) {
    console.error('Submission error:', error);
    alert('There was a problem submitting your request. Please check your connection and try again.');
  } finally {
    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.style.opacity = '1';
      submitBtn.style.cursor = 'pointer';
    }
  }
}



window.goToForm = function() {
  const filtered = PRODUCTS.filter(p => p.category === activeCategory);
  let loadedMore = false;
  
  // Force load all remaining products synchronously to stabilize DOM height
  while (currentPage * pageSize < filtered.length) {
    currentPage++;
    renderProducts(true);
    loadedMore = true;
  }
  
  // Scroll to preorder form (delay slightly if we just injected lots of nodes)
  setTimeout(() => {
    document.getElementById('preorder')?.scrollIntoView({ behavior:'smooth', block:'start' });
  }, loadedMore ? 150 : 0);
}

// ── Details Modal Logic ───────────────────────────────────────
function openDetailsModal(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  const imgEl = document.getElementById('details-img');
  if (imgEl) {
    imgEl.src = p.img;
    imgEl.setAttribute('data-zoom-src', p.img);
  }
  document.getElementById('details-title').textContent = p.name;
  document.getElementById('details-size').textContent = p.caseSize;
  document.getElementById('details-desc').innerHTML = p.description;
  document.getElementById('details-price').textContent = '$' + p.price.toFixed(2);
  
  const modalQty = document.getElementById('modal-qty');
  if(modalQty) {
    modalQty.dataset.id = p.id;
    modalQty.value = p.qty;
  }
  
  const modalLine = document.getElementById('modal-line');
  if(modalLine) {
    if (p.qty > 0) {
      modalLine.textContent = `Subtotal: $${(p.qty * p.price).toFixed(2)} CAD`;
      modalLine.classList.remove('hidden');
    } else {
      modalLine.classList.add('hidden');
    }
  }

  document.getElementById('details-modal')?.classList.remove('hidden');
}

function modalChangeQty(delta) {
  const modalQty = document.getElementById('modal-qty');
  if(!modalQty) return;
  const id = parseInt(modalQty.dataset.id);
  if (id) changeQty(id, delta);
}

function modalSetQty(val) {
  const modalQty = document.getElementById('modal-qty');
  if(!modalQty) return;
  const id = parseInt(modalQty.dataset.id);
  if (id) setQty(id, val);
}

function closeDetailsModal() {
  document.getElementById('details-modal')?.classList.add('hidden');
}

// ── Init ──────────────────────────────────────────────────────
renderFilters();
renderProducts();

// Setup Infinite Scroll
const sentinelEl = document.getElementById('sentinel');
if (sentinelEl) {
  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      loadMoreProducts();
    }
  }, { rootMargin: '200px' });
  observer.observe(sentinelEl);
}
</script>
