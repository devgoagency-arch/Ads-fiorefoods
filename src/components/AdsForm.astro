---
// src/components/AdsForm.astro
// Form component for Google Ads landing page - Canadian B2B retail catalog request
---

<div id="ads-preorder" class="bg-white rounded-3xl p-5 md:p-8 shadow-sm border border-cream">
  <div class="text-center mb-5 md:mb-8">
    <p class="font-rob font-medium text-[15px] tracking-[.2em] uppercase mb-1.5 md:mb-2" style="color:#acb370">Exclusive Access</p>
    <h2 class="font-cap text-xl md:text-2xl lg:text-3xl text-brand" style="color:#80131d">Contact Specialty Food Experts</h2>
    <p class="font-rob text-xs md:text-sm text-gray-500 mt-1 md:mt-2">Get wholesale catalog, pricing, and stock details within 24 business hours.</p>
  </div>

  <form id="ads-order-form" class="space-y-4 md:space-y-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3.5 md:gap-5">
      <!-- 1. BUSINESS NAME * -->
      <div class="flex flex-col gap-1 md:gap-1.5">
        <label class="font-rob text-xs md:text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Business Name <span style="color:#80131d">*</span></label>
        <input id="ads-f-business-name" name="business_name" type="text" required placeholder="Enter business name" class="fld w-full border border-gray-200 rounded-full px-4 py-2 md:py-2.5 text-sm md:text-base font-rob transition-all">
      </div>

      <!-- 2. CONTACT NAME * -->
      <div class="flex flex-col gap-1 md:gap-1.5">
        <label class="font-rob text-xs md:text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Contact Name <span style="color:#80131d">*</span></label>
        <input id="ads-f-contact-name" name="contact_name" type="text" required placeholder="Jane Smith" class="fld w-full border border-gray-200 rounded-full px-4 py-2 md:py-2.5 text-sm md:text-base font-rob transition-all">
      </div>

      <!-- 3. BUSINESS EMAIL * -->
      <div class="flex flex-col gap-1 md:gap-1.5">
        <label class="font-rob text-xs md:text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Business Email <span style="color:#80131d">*</span></label>
        <input id="ads-f-business-email" name="business_email" type="email" required placeholder="name@company.com" class="fld w-full border border-gray-200 rounded-full px-4 py-2 md:py-2.5 text-sm md:text-base font-rob transition-all">
      </div>

      <!-- 4. PROVINCE * (Ontario selected by default) -->
      <div class="flex flex-col gap-1 md:gap-1.5">
        <label class="font-rob text-xs md:text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Province <span style="color:#80131d">*</span></label>
        <div class="relative">
          <select id="ads-f-province" name="province" required class="fld w-full border border-gray-200 rounded-full px-4 py-2 md:py-2.5 text-sm md:text-base font-rob transition-all appearance-none bg-white pr-8">
            <option value="" disabled>Select province...</option>
            <option value="Ontario" selected>Ontario</option>
            <option value="Quebec">Quebec</option>
            <option value="British Columbia">British Columbia</option>
            <option value="Alberta">Alberta</option>
            <option value="Manitoba">Manitoba</option>
            <option value="Saskatchewan">Saskatchewan</option>
            <option value="Nova Scotia">Nova Scotia</option>
            <option value="New Brunswick">New Brunswick</option>
            <option value="Newfoundland and Labrador">Newfoundland and Labrador</option>
            <option value="Prince Edward Island">Prince Edward Island</option>
            <option value="Northwest Territories">Northwest Territories</option>
            <option value="Yukon">Yukon</option>
            <option value="Nunavut">Nunavut</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </div>

      <!-- 5. BUSINESS TYPE * -->
      <div class="flex flex-col gap-1 md:gap-1.5">
        <label class="font-rob text-xs md:text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Business Type <span style="color:#80131d">*</span></label>
        <div class="relative">
          <select id="ads-f-business-type" name="business_type" required class="fld w-full border border-gray-200 rounded-full px-4 py-2 md:py-2.5 text-sm md:text-base font-rob transition-all appearance-none bg-white pr-8">
            <option value="" disabled selected>Select type...</option>
            <option>Specialty Food Store</option>
            <option>Restaurant / Café</option>
            <option>Cheese Shop</option>
            <option>Online Market</option>
            <option>Hotel / Hospitality</option>
            <option>Supermarket / Grocery</option>
            <option>Distributor / Wholesale</option>
            <option>Other</option>
          </select>
          <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </div>

      <!-- 6. BUSINESS WEBSITE * -->
      <div class="flex flex-col gap-1 md:gap-1.5">
        <label class="font-rob text-xs md:text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Business Website <span style="color:#80131d">*</span></label>
        <input id="ads-f-business-website" name="business_website" type="text" required placeholder="www.yourwebsite.com" class="fld w-full border border-gray-200 rounded-full px-4 py-2 md:py-2.5 text-sm md:text-base font-rob transition-all">
      </div>
    </div>

    <div class="mt-5 md:mt-7 text-center">
      <!-- Consent checkbox linking to privacy policy -->
      <div class="mb-4 flex items-center justify-center">
        <label class="font-rob text-xs text-gray-600 flex items-center gap-2">
          <input id="ads-f-privacy" name="privacy_consent" type="checkbox" class="h-4 w-4" />
          <span>I agree to the <a href="/privacy-policy" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">Privacy Policy</a></span>
        </label>
      </div>

      <!-- Cloudflare Turnstile container -->
      <div class="cf-turnstile mb-3 md:mb-4 flex justify-center" data-sitekey="0x4AAAAAADT3pQj5vkuU0Bn1"></div>
      
      <button type="submit" class="btn btn-red px-10 py-3 md:py-3.5 font-cap text-sm md:text-base w-full sm:w-auto">
        Request Our Wholesale Catalogue
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
        </svg>
      </button>
      
      <p class="text-gray-400 text-xs mt-2.5 md:mt-3 font-rob">
        We'll reply within 24 business hours
      </p>
    </div>
  </form>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('ads-order-form');
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
        submitBtn.style.cursor = 'not-allowed';
      }

      const turnstileResponse = document.querySelector('[name="cf-turnstile-response"]')?.value;

      const consentChecked = document.getElementById('ads-f-privacy')?.checked;
      if (!consentChecked) {
        alert('Please accept the Privacy Policy to continue.');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          submitBtn.style.cursor = 'pointer';
        }
        return;
      }

      const payload = {
        businessName: document.getElementById('ads-f-business-name').value.trim(),
        contactName: document.getElementById('ads-f-contact-name').value.trim(),
        businessEmail: document.getElementById('ads-f-business-email').value.trim(),
        province: document.getElementById('ads-f-province').value,
        businessType: document.getElementById('ads-f-business-type').value,
        businessWebsite: document.getElementById('ads-f-business-website').value.trim(),
        turnstile_token: turnstileResponse,
        privacy_consent: Boolean(consentChecked),
        timestamp: new Date().toISOString()
      };

      try {
        const response = await fetch('https://hook.eu1.make.com/p2y0iv7yw5or87vjmhkniwf2fjd1ejyo', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        if (response.ok) {
          form.reset();

          if (window.turnstile) {
            window.turnstile.reset();
          }

          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: 'ads_form_submit',
            conversionValue: 0.00,
            currency: 'CAD',
            leadSource: 'Google Ads Landing'
          });

          alert('Your request has been successfully submitted! We will reach out to you shortly.');
        } else {
          alert('There was a problem submitting your request. Please try again.');
        }
      } catch (error) {
        console.error('Submission error:', error);
        alert('There was a network problem. Please check your connection and try again.');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          submitBtn.style.cursor = 'pointer';
        }
      }
    });
  });
</script>
