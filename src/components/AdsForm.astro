---
// src/components/AdsForm.astro
// Componente de formulario exclusivo para la Landing Page de Google Ads
---

<section id="ads-preorder" class="py-16 bg-cream">
  <div class="max-w-3xl mx-auto px-6">

    <div class="text-center mb-10">
      <p class="font-rob font-medium text-xs tracking-[.2em] uppercase mb-2" style="color:#acb370">Exclusive Access</p>
      <h2 class="font-cap text-3xl" style="color:#a81624">Contact Our Specialty Food Experts</h2>
      <p class="font-rob text-sm text-gray-500 mt-2">Get wholesale catalog, pricing, and stock details within 24 business hours.</p>
    </div>

    <!-- Formulario optimizado para conversión (1 columna en móvil, 2 en md+) -->
    <form id="ads-order-form" class="bg-white rounded-3xl p-8 shadow-sm border border-cream">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <div class="flex flex-col gap-1.5">
          <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Full Name <span style="color:#80131d">*</span></label>
          <input id="ads-f-name" name="name" type="text" required placeholder="Jane Smith" class="fld w-full border border-gray-200 rounded-full px-4 py-2.5 text-base font-rob transition-all">
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Company Name <span style="color:#80131d">*</span></label>
          <input id="ads-f-company" name="company" type="text" required placeholder="Acme Fine Foods Inc." class="fld w-full border border-gray-200 rounded-full px-4 py-2.5 text-base font-rob transition-all">
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Email Address <span style="color:#80131d">*</span></label>
          <input id="ads-f-email" name="email" type="email" required placeholder="jane@acmefoods.ca" class="fld w-full border border-gray-200 rounded-full px-4 py-2.5 text-base font-rob transition-all">
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Business Category <span style="color:#80131d">*</span></label>
          <div class="relative">
            <select id="ads-f-category" name="category" required class="fld w-full border border-gray-200 rounded-full px-4 py-2.5 text-base font-rob transition-all appearance-none bg-white pr-8">
              <option value="" disabled selected>Select your category…</option>
              <option>Specialty Food Store</option>
              <option>Restaurant / Café</option>
              <option>Cheese Shop</option>
              <option>Online Market</option>
              <option>Hotel / Hospitality</option>
              <option>Supermarket / Grocery</option>
              <option>Other</option>
            </select>
            <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </div>
        </div>

      </div>

      <div class="flex flex-col gap-1.5 mt-5">
        <label class="font-rob text-sm font-medium uppercase tracking-wide" style="color:#1a1a1a">Additional Notes</label>
        <textarea id="ads-f-notes" name="notes" rows="3" placeholder="Tell us about your seasonal needs, special requests..." class="fld w-full border border-gray-200 rounded-2xl px-4 py-3 text-base font-rob transition-all resize-none"></textarea>
      </div>

      <div class="mt-7 text-center">
        <!-- 
          CF Turnstile: Reemplaza 'data-sitekey' con tu clave real de producción de Cloudflare Turnstile.
          El key actual es el del entorno B2B.
        -->
        <!-- ── CLAVE SITIO DE TURNSTILE ── -->
        <div class="cf-turnstile mb-4 flex justify-center" data-sitekey="0x4AAAAAADGdWFU5FsRD_Aa5"></div>
        
        <div class="flex flex-col-reverse sm:flex-row items-center justify-center gap-4">
          <button type="submit" class="btn btn-red px-10 py-3.5 font-cap text-base w-full sm:w-auto">
            Send Inquiry Request
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>
        </div>
        <p class="text-gray-400 text-xs mt-3 font-rob">
          This is an inquiry request. A Fiore Foods representative will follow up shortly.
        </p>
      </div>

    </form>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('ads-order-form');
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const turnstileToken = formData.get('cf-turnstile-response');
      
      if (!turnstileToken) {
        alert('Please complete the security check to prove you are human.');
        return;
      }

      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
        submitBtn.style.cursor = 'not-allowed';
      }

      const payload = {
        event_type: 'ads_landing_submission',
        turnstile_token: turnstileToken,
        timestamp: new Date().toISOString(),
        source: 'fiore-google-ads-landing',
        customer_info: {
          name: document.getElementById('ads-f-name').value.trim(),
          company: document.getElementById('ads-f-company').value.trim(),
          email: document.getElementById('ads-f-email').value.trim(),
          category: document.getElementById('ads-f-category').value,
          notes: document.getElementById('ads-f-notes').value.trim() || null,
        }
      };

      try {
        // ── DIRECCIÓN DEL WEBHOOK DE MAKE ──
        // Reemplaza esta URL con la dirección de tu escenario exclusivo de Google Ads en Make
        const webhookUrl = 'https://hook.eu1.make.com/YOUR_NEW_ADS_WEBHOOK_HERE';
        
        const response = await fetch(webhookUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        if (response.ok) {
          form.reset();

          // Resetear Turnstile widget si existe
          if (window.turnstile) {
            window.turnstile.reset();
          }

          // ── ARQUITECTURA DE TRACKING (GTM) ──
          // Disparamos el evento personalizado en el dataLayer para Google Ads
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: 'ads_form_submit',
            conversionValue: 0.00,
            currency: 'CAD',
            leadSource: 'Google Ads Landing'
          });

          alert('Your request has been successfully submitted! We will reach out to you shortly.');
        } else {
          console.error('[Ads Form] Webhook returned status:', response.status);
          alert('There was a problem submitting your request. Please try again.');
        }
      } catch (error) {
        console.error('[Ads Form] Network/Submission error:', error);
        alert('There was a network problem. Please check your connection and try again.');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          submitBtn.style.cursor = 'pointer';
        }
      }
    });
  });
</script>
